{
  "name": "luna-ai-web-os",
  "version": "1.0.0",
  "description": "The futuristic AI Web OS desktop application.",
  "main": "main.js",
  "scripts": {
    "start": "vite build && electron .",
    "boot": "electron .",
    "dist": "electron-builder",
    "dev": "vite",
    "build": "vite build"
  },
  "author": "Aryan & Luna",
  "license": "ISC",
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^24.13.3",
    "vite": "^8.1.3"
  },
  "build": {
    "appId": "com.luna.webos",
    "productName": "Luna AI Web OS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!venv${/*}",
      "!scratch${/*}",
      "!.git${/*}",
      "!dist${/*}"
    ],
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    }
  },
  "dependencies": {
    "jsdom": "^29.1.1",
    "selenium-webdriver": "^4.46.0",
    "systeminformation": "^5.31.17"
  }
}
